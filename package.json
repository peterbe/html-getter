{
  "name": "html-getter",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "html-getter": "bun run src/html-getter.ts",
    "build": "bun build src/html-getter.ts --target=bun --outfile out/html-getter --compile --bytecode",
    "build:linux-arm64": "bun build src/html-getter.ts --target=bun-linux-arm64 --outfile out/html-getter-linux-arm64 --compile --bytecode",
    "build:linux-x64": "bun build src/html-getter.ts --target=bun-linux-x64 --outfile out/html-getter-linux-x64 --compile --bytecode"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
